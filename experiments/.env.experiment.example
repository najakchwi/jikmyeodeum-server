# /home/ubuntu/.env.experiment으로 복사한 뒤 실제 값으로 교체한다.
# 기존 /home/ubuntu/.env의 전체 구조를 복사하고, 아래 DB 값만 실험 Supabase 프로젝트로 바꾸는 편이 안전하다.

DB_URL=jdbc:postgresql://db.{SUPABASE_EXPERIMENT_PROJECT_REF}.supabase.co:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD={SUPABASE_EXPERIMENT_DB_PASSWORD}

# 애플리케이션 기동에 필요한 나머지 값은 기존 개발 .env에서 복사한다.
JWT_SECRET={EXPERIMENT_JWT_SECRET_AT_LEAST_32_CHARS}
KAKAO_REST_API_KEY=
KAKAO_APP_KEY=
KAKAO_JWKS_URI=https://kauth.kakao.com/.well-known/jwks.json
KAKAO_ISSUER=https://kauth.kakao.com
GOOGLE_CLIENT_ID=
GOOGLE_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_ISSUER=https://accounts.google.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
DISCORD_WEBHOOK_CRITICAL=
DISCORD_WEBHOOK_WARNING=
DISCORD_WEBHOOK_INFO=
DISCORD_WEBHOOK_METRICS=
